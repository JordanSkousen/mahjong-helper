(defn display-group
  [s]
  (let [[mul val suit] s
        color (case suit
                "a" "#d18e29"
                "b" "#6fc7b3"
                "c" "#6a52a2"
                "black")]
    [:span.group {:style {:color color}}
     (repeat (int mul)
             (cond
               ;; suitless icon
               (some #{val} ["F" "N" "E" "W" "S"])
               [:img {:src (str "/img/" val ".svg")
                      :alt val}]
               
               ;; suited icon (dragon)
               (= val "D")
               [(->> tile-keys
                     (filter #(= (:key %) "Dragon"))
                     first
                     :icon) {:fill color}]

               ;; sequential letter
               (string/includes? WILDS1 val)
               (.charCodeAt "r")))]))
