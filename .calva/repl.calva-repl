(defn pv-wild-map
  ([pattern-val tile-val]
   (pv-wild-map pattern-val tile-val false))
  ([pattern-val tile-val _2?]
   (let [arr (if _2? "ijklmnopq" "rstuvwxyz") 
         p-idx (string/index-of arr pattern-val)
         tile-val' (js/Number.parseInt tile-val)
         start (- tile-val' p-idx)]
     (zipmap arr 
             (range start (+ start (count arr) 1))))))
