(defn display-group
  [s]
  (let [[mul val suit] s]
    [:span {:style {:color (case suit
                             "b" "green"
                             "c" "red"
                             "black")}}
     (repeat (js/Number.parseInt mul) (case val
                                        "v" "1"
                                        "w" "2"
                                        "x" "3"
                                        "y" "4"
                                        "z" "5"
                                        "o" "1"
                                        "e" "2"
                                        val))]))
