(defn matches-pattern
  [context pattern tile]
  (let [[pattern-mul pattern-val pattern-suit] pattern
        [tile-val tile-suit] tile
        val-match (cond
                    ;; tile is joker
                    (and (= tile-val "J")
                         (> (js/Number.parseInt pattern-mul) 2))
                    {:result true}
                    ;; tile is number, pattern is r-z val, and none picked in context yet
                    (and (number?* tile-val)
                         (pv-wild-num? pattern-val)
                         (nil? (get context pattern-val)))
                    {:result true
                     :context (merge context (pv-wild-map pattern-val tile-val))}
                    ;; tile is number, pattern is r-z val, and matches one picked in context
                    (and (number?* tile-val)
                         (pv-wild-num? pattern-val)
                         (= (get context pattern-val) tile-val))
                    {:result true}
                    ;; tile is number, pattern is i-q val, and none picked in context yet
                    (and (number?* tile-val)
                         (pv-wild-num2? pattern-val)
                         (nil? (get context pattern-val)))
                    {:result true
                     :context (merge context (pv-wild-map pattern-val tile-val true))}
                    ;; tile is number, pattern is i-q val, and matches one picked in context
                    (and (number?* tile-val)
                         (pv-wild-num2? pattern-val)
                         (= (get context pattern-val) tile-val))
                    {:result true}
                    ;; tile is specific number
                    (= tile-val pattern-val)
                    {:result true})
        suit-match (cond
                     ;; suit not applicable
                     (and (= pattern-suit ".")
                          (= tile-suit "."))
                     {:result true}
                     ;; suit not picked in context yet 
                     (nil? (get context pattern-suit))
                     {:result true
                      :context (assoc context pattern-suit tile-suit)}
                     ;; suit picked in context matches
                     (= (get context pattern-suit) tile-suit)
                     {:result true})]
    {:result (boolean (and (:result val-match) (:result suit-match)))
     :context (merge context
                     (:context val-match)
                     (:context suit-match))}))
